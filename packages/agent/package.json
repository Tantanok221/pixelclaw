{
  "name": "agent",
  "version": "1.0.0",
  "private": true,
  "description": "Pixelbot agent runtime",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src test vitest.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.56.3",
    "@mariozechner/pi-ai": "^0.56.3",
    "dotenv": "^17.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
