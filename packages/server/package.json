{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "Pixelclaw Fastify chat backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src test vitest.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9"
  }
}
