{
  "name": "pixelclaw",
  "version": "1.0.0",
  "private": true,
  "description": "Pixelclaw monorepo",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=server --filter=web",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev:agent": "npm run dev --workspace=agent --",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "start": "npm run start --workspace=server",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --filter=server --filter=web --filter=agent",
    "lint": "turbo run lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "osfmt": "oxfmt ."
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
