{
  "name": "cli",
  "version": "1.0.0",
  "private": true,
  "description": "Pixelclaw admin CLI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "auth:agent": "tsx src/auth.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pair:telegram": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src test vitest.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  }
}
